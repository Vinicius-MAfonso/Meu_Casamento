# Reference for the environment variables the app needs in production.
# Set these in the Render Dashboard under your web service's Settings ->
# Environment tab -- Render injects them directly, it doesn't read a
# .env.prod file from disk.

DJANGO_ENV=production

# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

DEBUG=False

# Your custom domain, if any. Render's own <service>.onrender.com hostname is
# added automatically (see RENDER_EXTERNAL_HOSTNAME in settings.py) -- you
# don't need to list it here.
ALLOWED_HOSTS=meucasamento.example.com

# From your Render Postgres instance's Info page. Prefer the "Internal
# Database URL" if the web service and database are in the same region --
# it's faster and doesn't require SSL. Use the "External Database URL" only
# if connecting from outside Render.
DATABASE_URL=postgres://user:password@host/dbname

