# Copy this file to .env.local and fill in real values for local development.
#   cp .env.local.example .env.local

DJANGO_ENV=development

# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-random-secret-key

DEBUG=True

# Comma-separated, no spaces needed. Required even locally -- if this is left
# blank, ALLOWED_HOSTS ends up empty and Django's runserver will reject every
# request with DisallowedHost.
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave blank to fall back to a local db.sqlite3 file, or point at a real DB, e.g.:
#   DATABASE_URL=postgres://user:password@localhost:5432/meu_casamento
DATABASE_URL=

# Set to true to also write logs to logs/django.log while developing locally.
LOG_TO_FILE=false
